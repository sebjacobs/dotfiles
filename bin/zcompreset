#!/usr/bin/env ruby
# frozen_string_literal: true

# zcompreset — clear zsh's completion cache (~/.zcompdump*).
#
# zsh caches the functions it found on $fpath in ~/.zcompdump and, when started
# with `compinit -C`, trusts that cache without rescanning. So a completion
# installed after the cache was built — e.g. `rake install` dropping a _foo into
# ~/.local/share/zsh/site-functions — stays invisible, and the shell falls back
# to filename completion, until the dump is thrown away. Removing every
# ~/.zcompdump* forces the next shell to rebuild it clean.
#
# It cannot re-exec the interactive shell that called it (a subprocess can't),
# so it clears the cache and points at the one manual step left: `exec zsh`.
#
# Usage: zcompreset

require "fileutils"

dumps = Dir.glob(File.join(Dir.home, ".zcompdump*"))

if dumps.empty?
  puts "No ~/.zcompdump* files to remove."
else
  FileUtils.rm_f(dumps)
  puts "Removed #{dumps.length} completion cache file#{"s" unless dumps.length == 1}:"
  dumps.sort.each { |path| puts "  #{path.sub(Dir.home, "~")}" }
end

puts
puts "Restart your shell to rebuild completions:  exec zsh"
