#compdef gwt

# Completion for `gwt` (zsh/gwt.zsh — git worktree helpers for .claude/worktrees/).
#
# First word: the subcommands, kept in sync with Gwt::SUBCOMMANDS by the
# completion-drift smoke test (test/shell/completion_drift_test.rb). The
# worktree-taking subcommands (cd/rm/path/zed/mv/sync) complete an existing
# worktree's name from the .claude/worktrees/ dirs; add completes branch names.
# mv's second word (the new name) is free text.

_gwt_root() { git worktree list --porcelain 2>/dev/null | head -1 | sed 's/^worktree //'; }

_gwt() {
  local root=$(_gwt_root)
  if [[ -z "$root" ]]; then return; fi
  local wt_base="$root/${GWT_WORKTREE_DIR:-.claude/worktrees}"

  if (( CURRENT == 2 )); then
    zstyle ':completion:*:*:gwt:*' group-name ''
    zstyle ':completion:*:*:gwt:*' group-order commands worktrees
    local -a _subcommands=(add sync cd mv path zed ls rm prune root status)  # @subcommands
    compadd -J commands -X 'commands' -- $_subcommands
    if [[ -d "$wt_base" ]]; then
      compadd -J worktrees -X 'worktrees' -- "$wt_base"/*(/:t)
    fi
  elif (( CURRENT == 3 )); then
    case "${words[2]}" in
      cd|rm|path|zed|mv|sync)
        if [[ -d "$wt_base" ]]; then
          compadd -- "$wt_base"/*(/:t)
        fi
        ;;
      add)
        # Complete branch names
        compadd -- $(git branch --format='%(refname:short)' 2>/dev/null)
        ;;
      root)
        compadd -- -p --path
        ;;
    esac
  fi
}

_gwt "$@"
