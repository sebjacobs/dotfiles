{
  "permissions": {
    "allow": [
      "Bash(chafa *)",
      "Bash(ffprobe *)",
      "Bash(gh api *)",
      "Bash(gh auth status)",
      "Bash(gh browse *)",
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr close *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr create *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr list *)",
      "Bash(gh pr ready *)",
      "Bash(gh pr reopen *)",
      "Bash(gh pr status *)",
      "Bash(gh pr view *)",
      "Bash(gh release download *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh repo list *)",
      "Bash(gh repo view *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git cherry-pick *)",
      "Bash(git commit *)",
      "Bash(git fetch *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(git stash *)",
      "Bash(jotter *)",
      "Edit",
      "Read",
      "WebFetch",
      "WebSearch",
      "Write",
      "Bash(jotter:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)"
    ],
    "defaultMode": "default"
  },
  "model": "opus",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "effortLevel": "medium",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  }
}
